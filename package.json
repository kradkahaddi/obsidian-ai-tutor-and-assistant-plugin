{
  "name": "obsidian-local-gemma",
  "version": "0.0.1",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --external:obsidian --external:@codemirror/* --sourcemap=inline --watch",
